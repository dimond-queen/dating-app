{
  "name": "video-dating-app",
  "version": "1.0.0",
  "description": "A video call dating app with real-time communication",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"php artisan serve --host=0.0.0.0 --port=12000\" \"cd client && npm run dev -- --host=0.0.0.0 --port=12001\"",
    "server": "php artisan serve --host=0.0.0.0 --port=12000",
    "client": "cd client && npm run dev -- --host=0.0.0.0 --port=12001",
    "build": "cd client && npm run build",
    "start": "php artisan serve"
  },
  "keywords": ["dating", "video-call", "webrtc", "react", "laravel"],
  "author": "OpenHands",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "axios": "^1.8.2",
    "laravel-vite-plugin": "^1.2.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.2.4"
  }
}
